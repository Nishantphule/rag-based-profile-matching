# Copy to `.env` and fill in. The .env file is gitignored.
#
# Required for `--use-llm` / OpenRouterReasoner.
OPENROUTER_API_KEY=

# Optional - defaults to openai/gpt-5.2
# OPENROUTER_MODEL=openai/gpt-5.2

# Optional - defaults to https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional - shown on OpenRouter rankings
# OPENROUTER_SITE_URL=
# OPENROUTER_SITE_NAME=
